generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  emailAccounts EmailAccount[]
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  calendarAccount CalendarAccount?
  teamInboxes     TeamInbox[] @relation("TeamInboxMembers")
  presence        UserPresence?
  comments        Comment[]
  activities      ActivityLog[]
  workflowsCreated Workflow[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  users     User[]
  emails    Email[]
  knowledge KnowledgeItem[]
  quickAnalyses QuickAnalysis[]
  settings  Settings?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  analyticsSnapshots AnalyticsSnapshot[]
  aiPerformanceLogs  AIPerformanceLog[]
  calendarAccounts   CalendarAccount[]
  calendarEvents     CalendarEvent[]
  teamInboxes        TeamInbox[]
  comments           Comment[]
  activityLogs       ActivityLog[]
  workflows          Workflow[]
  meetingRecordings  MeetingRecording[]
}

model EmailAccount {
  id           String   @id @default(cuid())
  userId       String
  provider     String
  accessToken  String   @db.Text
  refreshToken String   @db.Text
  email        String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  emails       Email[]
}

model Email {
  id          String   @id @default(cuid())
  orgId       String
  accountId   String
  messageId   String   @unique
  threadId    String?
  subject     String
  fromEmail   String
  fromName    String?
  toEmail     String
  body        String   @db.Text
  bodyHtml    String?  @db.Text
  snippet     String?  @db.Text
  receivedAt  DateTime
  category    String?
  priority    String?
  intent      String?
  sentiment   String?
  isProcessed Boolean  @default(false)
  aiDraft     String?  @db.Text
  status      String   @default("RECEIVED")
  sentAt      DateTime?

  aiModelUsed       String?  @default("gpt-4o-mini")
  draftEditDistance Float?
  wasApprovedAsIs   Boolean  @default(false)
  dealValue         Float?
  currency          String   @default("USD")
  calendarEventId   String?
  teamInboxId       String?

  account      EmailAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  calendarEvents CalendarEvent[]
  teamInbox      TeamInbox? @relation(fields: [teamInboxId], references: [id])
  comments       Comment[]
}

model KnowledgeItem {
  id        String   @id @default(cuid())
  orgId     String
  title     String
  content   String   @db.Text
  type      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
}

model QuickAnalysis {
  id          String   @id @default(cuid())
  orgId       String
  content     String   @db.Text
  category    String
  priority    String
  intent      String
  sentiment   String
  leadScore   Int
  summary     String
  draft       String   @db.Text
  status      String   @default("analyzed") // analyzed | used | edited | sent
  pipelineStage String @default("New Lead")
  createdAt   DateTime @default(now())
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  
  aiModelUsed       String?  @default("gpt-4o-mini")
  draftEditDistance Float?
  wasApprovedAsIs   Boolean  @default(false)
  sentAt            DateTime?
  source            String?  @default("manual") // "gmail_sync" | "manual" | "api"
  convertedToLead   Boolean  @default(false)
  suggestedMeetingTimes DateTime[] @default([])
  
  calendarEvents CalendarEvent[]
  comments       Comment[]
}

model Settings {
  id               String @id @default(cuid())
  orgId            String @unique
  smtpHost         String?
  smtpPort         Int?
  smtpUser         String?
  smtpPass         String?
  defaultTimes     String?
  aiTone           String?
  autoFollowUp     Boolean @default(false)
  followUpDelayDays Int @default(3)
  
  fineTunedModelId      String?
  fineTunedModelWeight  Float    @default(0.5)
  fineTunedModelEnabled Boolean  @default(false)
  
  org              Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
}

model AnalyticsSnapshot {
  id              String   @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  // Pipeline metrics
  totalLeads      Int
  leadsByStage    Json     // { "New Lead": 5, "Contacted": 3, ... }
  avgLeadScore    Float
  conversionRate  Float    // percentage
  
  // AI Performance
  totalDrafts     Int
  approvedAsIs    Int
  approvalRate    Float
  avgEditDistance Float    // Levenshtein distance normalized
  
  // Revenue
  pipelineValue   Float
  weightedForecast Float
  
  // Time series
  periodStart     DateTime
  periodEnd       DateTime
  granularity     String   // "daily", "weekly", "monthly"
  
  createdAt       DateTime @default(now())
  
  @@index([organizationId, periodStart])
  @@index([organizationId, granularity])
}

model AIPerformanceLog {
  id              String   @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  // Draft tracking
  draftId         String   // references QuickAnalysis or Email
  draftType       String   // "quick_analysis" | "email_reply"
  
  originalDraft   String   @db.Text
  finalDraft      String?  @db.Text
  editDistance    Float?   // normalized Levenshtein
  
  // Outcome
  wasApproved     Boolean  // sent without changes
  wasEdited       Boolean  // user made changes
  wasRejected     Boolean  // user discarded
  
  // Timing
  draftGeneratedAt DateTime
  firstActionAt    DateTime?  // when user interacted
  sentAt           DateTime?
  
  // AI config
  modelUsed        String   @default("gpt-4o-mini")
  temperature      Float    @default(0.7)
  
  createdAt        DateTime @default(now())
  
  @@index([organizationId, draftGeneratedAt])
  @@index([organizationId, modelUsed])
}

model CalendarAccount {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  provider      String   // "google" | "outlook"
  email         String
  accessToken   String   @db.Text
  refreshToken  String   @db.Text
  expiryDate    DateTime
  
  isDefault     Boolean  @default(false)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([organizationId])
}

model CalendarEvent {
  id            String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  // Link to Aura entities
  emailId       String?
  email         Email?   @relation(fields: [emailId], references: [id])
  quickAnalysisId String?
  quickAnalysis QuickAnalysis? @relation(fields: [quickAnalysisId], references: [id])
  
  // Calendar details
  calendarEventId String   // Google/Outlook event ID
  calendarLink    String?
  meetLink        String?
  
  // Event details
  title         String
  description   String?  @db.Text
  startTime     DateTime
  endTime       DateTime
  attendees     String[] // Email addresses
  location      String?
  
  status        String   @default("confirmed") // confirmed | tentative | cancelled
  recording     MeetingRecording?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([organizationId, startTime])
  @@index([emailId])
}

model TeamInbox {
  id              String   @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name            String
  description     String?
  members         User[]   @relation("TeamInboxMembers")
  emails          Email[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  @@index([organizationId])
}

model UserPresence {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  status          String   @default("offline") // online, away, busy, offline
  currentView     String?  // "/pipeline", "/analytics", etc.
  lastActivity    DateTime @default(now())
  socketId        String?
  @@index([userId])
}

model Comment {
  id              String   @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  emailId         String?
  email           Email?   @relation(fields: [emailId], references: [id], onDelete: Cascade)
  quickAnalysisId String?
  quickAnalysis   QuickAnalysis? @relation(fields: [quickAnalysisId], references: [id], onDelete: Cascade)
  authorId        String
  author          User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  content         String   @db.Text
  parentId        String?
  parent          Comment? @relation("CommentReplies", fields: [parentId], references: [id])
  replies         Comment[] @relation("CommentReplies")
  mentions        String[] // user IDs
  isResolved      Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  @@index([organizationId, emailId])
  @@index([organizationId, quickAnalysisId])
}

model ActivityLog {
  id              String   @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actorId         String
  actor           User     @relation(fields: [actorId], references: [id], onDelete: Cascade)
  actionType      String   // "email_moved", "draft_approved", "comment_added", "meeting_scheduled", "stage_changed"
  targetType      String   // "Email", "QuickAnalysis", "Pipeline"
  targetId        String
  metadata        Json     // { fromStage: "New Lead", toStage: "Contacted", ... }
  createdAt       DateTime @default(now())
  @@index([organizationId, createdAt])
  @@index([actorId])
}

model Workflow {
  id              String   @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name            String
  description     String?
  triggerType     String   // "email_received", "stage_changed", "lead_score", "time_based", "manual"
  triggerConfig   Json     // { stage: "New Lead", minScore: 80, etc. }
  isActive        Boolean  @default(true)
  nodes           WorkflowNode[]
  executions      WorkflowExecution[]
  executionCount  Int      @default(0)
  lastExecutedAt  DateTime?
  createdById     String
  createdBy       User     @relation(fields: [createdById], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  @@index([organizationId, isActive])
}

model WorkflowNode {
  id              String   @id @default(cuid())
  workflowId      String
  workflow        Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  nodeType        String   // "condition", "action", "delay", "ai_draft", "send_email", "move_stage", "slack_notify", "webhook"
  config          Json     // node-specific config
  positionX       Float
  positionY       Float
  nextNodeId      String?
  nextNode        WorkflowNode? @relation("NodeFlow", fields: [nextNodeId], references: [id])
  previousNodes   WorkflowNode[] @relation("NodeFlow")
  createdAt       DateTime @default(now())
}

model WorkflowExecution {
  id              String   @id @default(cuid())
  workflowId      String
  workflow        Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  status          String   @default("running") // running, completed, failed, paused
  context         Json     // { emailId, leadId, variables }
  currentNodeId   String?
  startedAt       DateTime @default(now())
  completedAt     DateTime?
  errorMessage    String?
  logs            WorkflowExecutionLog[]
  @@index([workflowId, status])
}

model WorkflowExecutionLog {
  id              String   @id @default(cuid())
  executionId     String
  execution       WorkflowExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  nodeId          String
  nodeType        String
  input           Json
  output          Json
  status          String   // success, error, skipped
  executedAt      DateTime @default(now())
}

model MeetingRecording {
  id              String   @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  calendarEventId String   @unique
  calendarEvent   CalendarEvent @relation(fields: [calendarEventId], references: [id], onDelete: Cascade)
  
  // Recording details
  recordingUrl    String?
  transcription   String?  @db.Text
  summary         String?  @db.Text
  keyTopics       String[]
  actionItems     Json[]   // [{ text, assignee, dueDate, completed }]
  sentiment       Json     // { overall: "positive", breakdown: [...] }
  talkRatio       Json     // { salesRep: 0.4, prospect: 0.6 }
  
  // AI analysis
  dealInsights    String?  @db.Text
  riskFlags       String[]
  nextSteps       String[]
  
  // Status
  status          String   @default("scheduled") // scheduled, recording, processing, completed, failed
  processedAt     DateTime?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([organizationId, status])
  @@index([calendarEventId])
}
